---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import SearchBar from '../components/SearchBar.tsx';
import type { SearchItem } from '../components/SearchBar.tsx';
import ContinueReading from '../components/ContinueReading.tsx';

const allSummaries = await getCollection('summaries');

// Get unique series and unique books for the search data
const uniqueSeriesMap = new Map();
const searchDataMap = new Map<string, SearchItem>();

allSummaries.forEach(summary => {
  const seriesSlug = summary.data.series.toLowerCase().replace(/\s+/g, '-');
  const bookSlug = summary.data.book.toLowerCase().replace(/\s+/g, '-');

  // Build the unique Series list for the homepage grid
  if (!uniqueSeriesMap.has(seriesSlug)) {
    uniqueSeriesMap.set(seriesSlug, {
      seriesName: summary.data.series,
      url: `/${seriesSlug}`
    });
  }

  // Populate the Search Data array for the fuzzy finder
  const seriesKey = `series-${seriesSlug}`;
  if (!searchDataMap.has(seriesKey)) {
    searchDataMap.set(seriesKey, {
      type: 'Series',
      title: summary.data.series,
      url: `/${seriesSlug}`
    });
  }

  const bookKey = `book-${seriesSlug}-${bookSlug}`;
  if (!searchDataMap.has(bookKey)) {
    searchDataMap.set(bookKey, {
      type: 'Book',
      title: summary.data.book,
      subtitle: summary.data.series,
      url: `/${seriesSlug}/${bookSlug}`
    });
  }
});

const seriesList = Array.from(uniqueSeriesMap.values());
const searchData = Array.from(searchDataMap.values());
---

<Layout title="The Distiller | Narrative Summaries">
  <div class="max-w-4xl mx-auto py-12 px-4 sm:px-6">
    <div class="mb-12 flex flex-col items-center text-center">
      <h1 class="text-4xl md:text-5xl font-display font-semibold mb-6 tracking-wide text-cream-900 dark:text-cream-100 transition-colors duration-300">
        The Distiller Archive
      </h1>
      <p class="text-lg text-cream-600 dark:text-cream-300 leading-relaxed max-w-2xl mb-8 transition-colors duration-300">
        High-Density Narrative Summaries for returning readers.
        Select a series below to begin your refresher.
      </p>

      <SearchBar client:load searchData={searchData} />
    </div>

    <ContinueReading client:load />

    <div class="grid gap-5 md:grid-cols-2">
      {seriesList.map(series => (
        <a
          href={series.url}
          class="block group relative p-6 bg-cream-50 dark:bg-ink-800 rounded-lg border border-cream-300 dark:border-ink-700 hover:border-gold-400 dark:hover:border-gold-400 transition-all duration-200 shadow-sm hover:shadow-[0_4px_24px_rgba(201,168,76,0.10)]"
        >
          <div class="text-xs font-bold text-cream-500 dark:text-cream-500 uppercase tracking-[0.15em] mb-2 transition-colors duration-300">
            Series
          </div>
          <h2 class="text-2xl font-display font-semibold text-cream-900 dark:text-cream-100 group-hover:text-gold-600 dark:group-hover:text-gold-400 transition-colors duration-200">
            {series.seriesName}
          </h2>
          <div class="mt-4 text-cream-500 dark:text-cream-500 text-sm flex items-center transition-colors duration-300">
            Access Records
            <svg class="w-4 h-4 ml-2 group-hover:translate-x-1 group-hover:text-gold-500 dark:group-hover:text-gold-400 transition-all duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</Layout>
